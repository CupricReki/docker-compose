# Streamystats — copy to `.env` under `/opt/streamystats/` (service-only; globals from dc / global.env).
# Upstream: https://github.com/fredrikburmester/streamystats
#
# Iframes (Homepage, etc.): upstream sets X-Frame-Options: DENY in apps/nextjs-app/proxy.ts — not
# configurable via env. Override at your reverse proxy (strip that header, set CSP frame-ancestors
# to your dashboard origins). See comment block in docker-compose.yml.
#
# Defaults match docker-compose.yml (${VAR:-value}); uncomment to override.

# STREAMYSTATS_PORT=3000
# STREAMYSTATS_VERSION=latest
# STREAMYSTATS_VECTORCHORD_IMAGE=tensorchord/vchord-postgres:pg17-v0.4.1
# STREAMYSTATS_DB_PATH=/opt/streamystats/vectorchord
# STREAMYSTATS_POSTGRES_USER=postgres
# STREAMYSTATS_POSTGRES_DB=streamystats

# STREAMYSTATS_SESSION_POLL_INTERVAL_MS=5000
# STREAMYSTATS_SKIP_STARTUP_FULL_SYNC=false
# Cron schedules (standard cron syntax); defaults match upstream compose.
# STREAMYSTATS_CRON_ACTIVITY_SYNC=*/1 * * * *
# STREAMYSTATS_CRON_RECENT_ITEMS_SYNC=*/1 * * * *
# STREAMYSTATS_CRON_USER_SYNC=*/1 * * * *
# STREAMYSTATS_CRON_PEOPLE_SYNC=*/15 * * * *
# STREAMYSTATS_CRON_EMBEDDINGS_SYNC=*/15 * * * *
# STREAMYSTATS_CRON_GEOLOCATION_SYNC=*/5 * * * *
# STREAMYSTATS_CRON_FINGERPRINT_SYNC=0 4 * * *
# STREAMYSTATS_CRON_JOB_CLEANUP=*/1 * * * *
# STREAMYSTATS_CRON_OLD_JOB_CLEANUP=0 3 * * *
# STREAMYSTATS_CRON_FULL_SYNC=0 2 * * *
# STREAMYSTATS_CRON_DELETED_ITEMS_CLEANUP=0 * * * *

# Required (compose will error if unset):
# STREAMYSTATS_POSTGRES_PASSWORD: openssl rand -hex 32 | xargs -I{} sed -i 's/^STREAMYSTATS_POSTGRES_PASSWORD=.*/STREAMYSTATS_POSTGRES_PASSWORD={}/' .env
STREAMYSTATS_POSTGRES_PASSWORD=changeme
# STREAMYSTATS_SESSION_SECRET: openssl rand -hex 64 | xargs -I{} sed -i 's/^STREAMYSTATS_SESSION_SECRET=.*/STREAMYSTATS_SESSION_SECRET={}/' .env
STREAMYSTATS_SESSION_SECRET=changeme
# STREAMYSTATS_NEXT_SERVER_ACTIONS_ENCRYPTION_KEY: openssl rand -hex 16 | xargs -I{} sed -i 's/^STREAMYSTATS_NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=.*/STREAMYSTATS_NEXT_SERVER_ACTIONS_ENCRYPTION_KEY={}/' .env
STREAMYSTATS_NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=changeme
