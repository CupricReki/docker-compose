# jesec/flood — copy to `/opt/flood/.env` (service-only; globals from dc / global.env).
# Upstream: https://github.com/jesec/flood
#
# Defaults match docker-compose.yml (${VAR:-value}); uncomment to override.

# FLOOD_TAG=latest
# FLOOD_PORT=3000
# FLOOD_PUBLISH_PORT=3000
# Override per-stack path only if needed (else use DOWNLOADS_TORRENTS from host env):
# FLOOD_ALLOWED_PATH=/custom/path

# DOWNLOADS_TORRENTS is required for the /data bind (torrent download root; set in host env / tp-environment).
# DOWNLOADS_TORRENTS=/mnt/vol2/media/downloads/torrents

# Bind mount for Flood file ops; must match paths the torrent client uses (see upstream Troubleshooting).

# Optional: no per-user Flood login (still uses session cookie). Requires client env block below.
# FLOOD_OPTION_auth=none
# rTorrent socket (pick one style; do not mix with qburl block):
# FLOOD_OPTION_rtsocket=/path/to/rtorrent.sock
# rTorrent TCP:
# FLOOD_OPTION_rthost=rtorrent
# FLOOD_OPTION_rtport=5000
# qBittorrent:
# FLOOD_OPTION_qburl=http://qbittorrent:8080
# FLOOD_OPTION_qbuser=admin
# FLOOD_OPTION_qbpass=changeme
# Transmission:
# FLOOD_OPTION_trurl=http://transmission:9091/transmission/rpc
# FLOOD_OPTION_truser=
# FLOOD_OPTION_trpass=
